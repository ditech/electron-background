{
  "name": "@dimensional-innovations/electron-background",
  "version": "3.0.3",
  "description": "A TypeScript library that simplifies Electron app initialization through a plugin-based architecture.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*"
  ],
  "keywords": [
    "vue",
    "electron",
    "background"
  ],
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/dimensional-innovations/electron-background.git"
  },
  "author": "Dimensional Innovations",
  "license": "ISC",
  "bugs": {
    "url": "https://gitlab.com/dimensional-innovations/electron-background/-/issues"
  },
  "homepage": "https://gitlab.com/dimensional-innovations/electron-background",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint ./src/**/*",
    "lint:fix": "eslint ./src/**/* --fix",
    "generate:docs": "jsdoc2md ./dist/* > API.md",
    "prepublish": "tsc"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "electron-devtools-installer": "^4.0.0",
    "electron-log": "^5.1.1",
    "electron-updater": "^6.1.7",
    "lodash.merge": "^4.6.2"
  },
  "devDependencies": {
    "@types/lodash.merge": "^4.6.9",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "electron": "^28.2.1",
    "eslint": "^8.56.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.1",
    "jsdoc-to-markdown": "^8.0.1",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "electron": ">=16.0.0"
  }
}
